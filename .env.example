# 财务模型知识图谱配置文件
# 复制此文件为 .env 并填入实际值

# ===== LLM API配置 =====

# SiliconFlow (推荐)
SILICONFLOW_API_KEY=your_siliconflow_api_key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct

# DeepSeek (备用)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Anthropic Claude (备用)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Ollama本地 (备用)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ===== 默认LLM后端 =====
# 可选: siliconflow, deepseek, claude, ollama
DEFAULT_LLM_BACKEND=siliconflow

# ===== 任务路由配置 =====
# 不同任务使用不同后端以优化成本
# 格式: 任务名=后端名
LLM_TASK_ROUTING_STRUCTURE_RECOGNITION=siliconflow
LLM_TASK_ROUTING_SEMANTIC_ANNOTATION=siliconflow
LLM_TASK_ROUTING_FORMULA_EXPLANATION=siliconflow
LLM_TASK_ROUTING_ANOMALY_DETECTION=siliconflow

# ===== 解析配置 =====
PARSE_BATCH_SIZE=50
PARSE_TIMEOUT_SECONDS=300